# ==========================================
# VARIABLES D'ENVIRONNEMENT - COMPTABLI
# Copiez ce fichier vers .env pour Docker
# ==========================================

# ── POSTGRESQL ────────────────────────────
POSTGRES_USER=comptabli
POSTGRES_PASSWORD=comptabli_pass
POSTGRES_DB=comptabli_db

# ── BACKEND NESTJS ────────────────────────
# URL de connexion à la base de données (format Prisma/TypeORM)
DATABASE_URL=postgresql://comptabli:comptabli_pass@postgres:5432/comptabli_db
# Secret pour générer les tokens JWT (à changer en production)
JWT_SECRET=super_secret_jwt_key_pour_comptabli_prod
# Environnement Node.js
NODE_ENV=production

# ── OCR SERVICE ───────────────────────────
# URL pour joindre le service OCR depuis le backend (réseau interne Docker)
OCR_SERVICE_URL=http://ocr-service:8000
